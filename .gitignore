# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Environment and config
.env
.env.*
*.secret
secrets/
*.key
*.pem

# VSCode and IDE configs
.vscode/
.idea/
*.swp

# Agent garbage
tectum_framework/agents/*/__pycache__/
tectum_framework/agents/*/*.pyc

# Docker-related
*.log
docker-compose.override.yml
docker-compose.*.yml
**/Dockerfile.*.backup
**/tmp/
**/.docker/
**/logs/
**/build/
**/.envrc

# Volumes and mounts
volumes/
data/
**/node_modules/
**/venv/
**/.venv/
**/__pycache__/
**/.pytest_cache/

# Ollama models & blobs
**/blobs/
**/.ollama/
root/.ollama/
models/
.ollama/

# OpenWebUI data (SQLite DBs and model cache)
open-webui-data/
**/webui_settings/
**/backend/data/

# System files
.DS_Store
Thumbs.db
*.bak
*.tmp
*.orig
*.old
*.tar.gz
*.zip

# GitHub files (optional)
*.tgz
*.lock
*.tar
*.gz

# Ignore readme auto-gen artifacts
README_autogen.md

# Committed templates (re-included despite the broad patterns above — no secrets)
!.env.example
!.env.standalone.example
!docker-compose.standalone.yml
!docker-compose.synology.yml
