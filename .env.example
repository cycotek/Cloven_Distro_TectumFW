# Postgres Database
DATABASE_USER=cloven_user
DATABASE_PASS=changeme
DATABASE_NAME=cloven_tectum
DATABASE_HOST=cloven_tectum_db
DATABASE_PORT=5432

# API
API_PORT=8000

# Fetcher
FETCHER_PORT=8001

# Ollama — points to the containerized Ollama service
OLLAMA_HOST=http://ollama:11434

# Quorum: comma-separated model names available in your Ollama instance
QUORUM_MODELS=mistral-nemo:12b,qwen2.5:7b,llama3.2:3b

# Model used for the final narrative synthesis step
SYNTHESIS_MODEL=deepseek-r1:14b

# Model used for direct (single-answer, no quorum) queries — fast small model
DIRECT_MODEL=llama3.2:3b

# Embedding model for semantic memory layer (must be pulled in Ollama)
# Pull with: docker exec cloven_ollama ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

# Cosine similarity threshold for memory cache hits [0.0–1.0]
# Higher = stricter matching (fewer hits); lower = broader matching
# 0.82 catches paraphrases ("how fast does light travel" ≈ "what is the speed of light")
# 0.88 requires very close phrasing; 0.75 is broadly permissive
MEMORY_SIMILARITY_THRESHOLD=0.82
