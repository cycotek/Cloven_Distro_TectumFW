# ─────────────────────────────────────────────────────────────────────────────
# TectumFW Standalone (MCP flavor) — environment template
#   cp .env.standalone.example .env   then edit the values below.
# Used by docker-compose.standalone.yml. No Ollama is bundled here.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub — used by git_push.sh for authenticated pushes (never commit real values)
GITHUB_USER=your_github_username
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ── Ollama (EXTERNAL) ────────────────────────────────────────────────────────
# This stack does NOT run Ollama. Point it at the Ollama you already have.
#   • Ollama on this same Docker host:        http://host.docker.internal:11434
#   • Ollama on another machine (bare metal):  http://192.168.1.50:11434
# NOTE: the Ollama box must listen on the network, i.e. start it with
#       OLLAMA_HOST=0.0.0.0 so it accepts LAN connections, not just localhost.
OLLAMA_HOST=http://host.docker.internal:11434

# ── Models (must already be pulled on that Ollama instance) ──────────────────
# The UI/MCP scrape /api/tags live, so these just set the defaults.
QUORUM_MODELS=mistral-nemo:12b,qwen2.5:7b,llama3.2:3b
SYNTHESIS_MODEL=deepseek-r1:14b
DIRECT_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
OPTIMIZER_MODEL=llama3.2:3b

# Cosine similarity threshold for memory cache hits [0.0–1.0]
MEMORY_SIMILARITY_THRESHOLD=0.82

# ── Non-standard host ports (avoid collisions on an existing host) ───────────
API_PORT=8800          # Web UI + REST API
FETCHER_PORT=8801      # Research fetcher service
MCP_PORT=8802          # MCP server (streamable-HTTP, served at /mcp)

# ── Postgres / pgvector ──────────────────────────────────────────────────────
# Default: the bundled cloven_tectum_db container (ships with this stack).
# DATABASE_HOST/DATABASE_PORT are how the app connects *inside* the Docker
# network — leave them as-is for the bundled DB (it always listens on 5432).
# DATABASE_HOST_PORT is only the host-facing port (for psql from your machine).
#
# To use an EXTERNAL Postgres instead: set DATABASE_HOST to its address and
# DATABASE_PORT to its port, then start only the app services
# (see docker-compose.standalone.yml header).
DATABASE_USER=cloven_user
DATABASE_PASS=changeme
DATABASE_NAME=cloven_tectum
DATABASE_HOST=cloven_tectum_db
DATABASE_PORT=5432
DATABASE_HOST_PORT=55432
